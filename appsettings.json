{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.NewRelic.Logs",
      "NewRelic.LogEnrichers.Serilog"
    ],
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "NewRelicLogs"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithNewRelicLogsInContext"
    ]
  },
  "AllowedHosts": "*",
  "AWS": {
    "Region": "us-east-2"
  },
  "S3": {
    "HighScoresBucket": "gatool-high-scores",
    "TeamUpdatesBucket": "gatool-team-updates",
    "TeamUpdatesHistoryBucket": "gatool-team-updates-history",
    "UserPreferencesBucket": "gatool-user-preferences"
  },
  "Redis": {
    "Host": "localhost",
    "Port": "6379",
    "UseTls": false,
    "Password": ""
  },
  "HighScoresLookbackDays": 7,
  "DryRun": false
}
