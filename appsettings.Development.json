{
  "KeyVaultUrl": "https://GAToolApiKeys.vault.azure.net",
  "Redis": {
    "Host": "localhost",
    "Port": "6379",
    "UseTls": false,
    "Password": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Azure": "Warning",
        "Azure.Core": "Warning",
        "Azure.Identity": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "DryRun": true
}
