# This example is for local development without Azure
DISABLE_REDIS=true
# Override the CORS allowlist. Defaults to gatool.org, beta.gatool.org, and
# localhost:3000. Comma-separated list of origins (no trailing slash).
# Cors__AllowedOrigins=https://gatool.org,https://beta.gatool.org,http://localhost:3000
SECRET_FRCApiKey="Basic KEY"
SECRET_FRCCurrentSeason=2025
SECRET_MailchimpAPIKey=
SECRET_MailchimpAPIURL=
SECRET_MailchimpListID=
SECRET_TBAApiKey=
SECRET_UserStorageConnectionString="UseDevelopmentStorage=true"